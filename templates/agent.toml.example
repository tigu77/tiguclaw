# agent.toml.example — tiguclaw 에이전트 템플릿 예시
# `tiguclaw market install <path>` 로 설치할 수 있습니다.

[package]
id = "my-agent"
version = "1.0.0"
author = "your-name"
license = "MIT"
description = "에이전트 역할 설명"
min_tiguclaw = "0.1.0"
tags = []

[agent]
name = "my-agent"
nickname = ""  # 선택사항, 없으면 name으로 표시 (같은 spec 여러 인스턴스 구분용)
description = "에이전트 역할 설명"
level = 2
persistent = true
clearance = "minimal"
team = ""  # 소속 팀 (선택사항, 예: "hotdeal-team")

[capabilities]
skills = ["shell", "read_file", "write_file"]
max_tool_iterations = 15
